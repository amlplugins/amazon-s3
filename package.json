{
  "name": "@amlplugins/amazon-s3",
  "version": "0.0.1",
  "description": "Native @aws-sdk/client-s3 SDK re-exported under the @amlplugins namespace — Amazon S3 — object storage, buckets, multipart upload, lifecycle, replication, presigned URLs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amlplugins/amazon-s3.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
